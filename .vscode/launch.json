{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DocFlow: Commit And Push",
      "type": "node-terminal",
      "request": "launch",
      "command": "powershell.exe -ExecutionPolicy Bypass -File \"${workspaceFolder}\\git_auto_push.ps1\" \"${input:commitMessage}\""
    },
    {
      "name": "DocFlow: Commit Only",
      "type": "node-terminal",
      "request": "launch",
      "command": "powershell.exe -ExecutionPolicy Bypass -File \"${workspaceFolder}\\git_auto_push.ps1\" \"${input:commitMessage}\" -NoPush"
    },
    {
      "name": "DocFlow: Push Dry Run",
      "type": "node-terminal",
      "request": "launch",
      "command": "powershell.exe -ExecutionPolicy Bypass -File \"${workspaceFolder}\\git_auto_push.ps1\" \"${input:commitMessage}\" -DryRun"
    }
  ],
  "inputs": [
    {
      "id": "commitMessage",
      "type": "promptString",
      "description": "Enter the Git commit message",
      "default": "feat: update project"
    }
  ]
}
