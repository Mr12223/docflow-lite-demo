{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "DocFlow: Auto Commit And Push",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\git_auto_push.ps1",
        "${input:commitMessage}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "DocFlow: Auto Commit Only",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\git_auto_push.ps1",
        "${input:commitMessage}",
        "-NoPush"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "DocFlow: Auto Push Dry Run",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\git_auto_push.ps1",
        "${input:commitMessage}",
        "-DryRun"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ],
  "inputs": [
    {
      "id": "commitMessage",
      "type": "promptString",
      "description": "Enter the Git commit message",
      "default": "feat: update project"
    }
  ]
}
